{
  "@context": {
    "@vocab": "https://etzhayyim.com/ns/actor#",
    "id": "@id",
    "type": "@type"
  },
  "id": "actor:watari",
  "type": "Actor",
  "name": "watari",
  "glyph": "渡り",
  "displayNameJa": "渡り (わたり)",
  "displayNameEn": "Watari — World Live Moving-Craft (Ship + Aircraft) Knowledge Graph",
  "purpose": "World live moving-craft knowledge graph — ingests the LIVE positions of public, transponder-broadcasting craft (ships via AIS, aircraft via ADS-B) into the kotoba Datom log as an append-only as-of trajectory; surfaces aggregate sea-lane / air-corridor / chokepoint / approach concentration routed to safety + collision-avoidance + congestion-easing + resilience. A situational-awareness map, NEVER a person-surveillance feed and NEVER a target-list. The kotoba-native successor to the legacy maps aismarine/aircraft_live + vessel tracking pipelines.",
  "purposeJa": "世界の移動体（船舶 AIS・航空機 ADS-B のリアルタイム位置）の知識グラフ。公開トランスポンダ放送のみを kotoba Datom 化し、最新 as-of fix を現在位置・fix 列を航跡として追記（非終末論）。海上レーン/航空路/チョークポイント/進入の集中を可視化し、安全・衝突回避・混雑緩和・冗長化へ routing。個人監視でも標的リストでもない。旧 maps/vessel の RisingWave 実装を kotoba-native へ載せ替えた後継。",
  "status": "R0-design-only",
  "tier": "B",
  "adr": "2606041827",
  "dependsOnAdr": ["2606012600", "2605262130", "2605312345", "2605215000", "2605241500", "2605192200"],
  "supersedes": {
    "actors": ["20-actors/maps (aismarine + aircraft_live pipelines)", "20-actors/vessel (tracking:ais + voyage)"],
    "reason": "legacy real-time position store was RisingWave (vertex_vessel_position / vertex_aircraft_state) + graph.write SQL — violates the kotoba-canonical-state substrate boundary (ADR-2605262130) and routed narration off-Murakumo (ADR-2605215000). See 00-contracts/lexicons/com/etzhayyim/watari/MIGRATION-NOTES.md."
  },
  "schema": ["00-contracts/schemas/moving-craft-ontology.kotoba.edn"],
  "substrate": {
    "state": "kotoba Datom log (ADR-2605312345) — IPFS block backend, MST ingress, Base L2 anchor; current position = latest as-of :craft.fix, trajectory = EAVT history (非終末論)",
    "largeAssets": "DataLad → IPFS (80-data/moving-craft) — NO git-lfs",
    "inference": "Murakumo-only (ADR-2605215000)",
    "sources": "PUBLIC transponder broadcasts only — AIS via AISStream.io, ADS-B via OpenSky Network + adsb.fi (all free public data); live ingest G7-gated"
  },
  "pairedActor": {
    "id": "actor:watatsuna",
    "glyph": "綿津綱",
    "relation": "watari is the DYNAMIC moving-craft observation face; watatsuna 綿津綱 is the STATIC submarine-cable observation face. They share chokepoint keywords (:malacca :luzon-strait :suez-red-sea :hormuz …): watari's LIVE vessel transit load composes with watatsuna's STATIC cable load over the SAME keyword into one maritime resilience picture. Sibling lineage with watatsumi 綿津見 (sea body) — the 海/空 path trilogy."
  },
  "distinctFrom": {
    "kami-autodrive / funadaiku / watatsumi": "those BUILD or CONTROL craft (GNC autopilot, shipyards, submersibles); watari only OBSERVES real-world craft positions. Observe ≠ control (N3). watari flies and sails nothing."
  },
  "integrates": ["actor:watatsuna", "actor:kanae", "actor:danjo", "actor:kabuto", "actor:tsumugi"],
  "cells": [
    {
      "id": "cell:watari.ingest",
      "method": "methods/ingest.py",
      "status": "R0 stub — design only",
      "input": "data/ingest/*.json (AISStream / OpenSky-shaped public broadcast batch)",
      "output": ["data/craft-graph.merged.kotoba.edn"],
      "pipeline": "public AIS/ADS-B batch → normalize to :craft/:craft.fix → dedup craft identity (seed wins) → append fixes",
      "gate": "G7 — live AISStream/OpenSky fetch requires WATARI_OPERATOR_GATE (Council); offline/sample mode default, tagged :representative (G5)"
    },
    {
      "id": "cell:watari.analyze",
      "method": "methods/analyze.py",
      "input": "data/seed-craft-graph.kotoba.edn (or data/craft-graph.merged.kotoba.edn)",
      "output": ["out/intel-report.md", "out/movement-situation.kotoba.edn"],
      "pipeline": "classify → latest as-of fix per craft → lane/corridor load (by kind) → chokepoint transit (composes w/ watatsuna) → approach congestion → freshness tail (aggregate-first)"
    }
  ],
  "lexiconNamespaces": [
    "com.etzhayyim.watari.registerCraft",
    "com.etzhayyim.watari.recordFix",
    "com.etzhayyim.watari.recordLeg",
    "com.etzhayyim.watari.registerLane"
  ],
  "supersedesLexicons": [
    "com.etzhayyim.apps.vessel.vesselPosition",
    "com.etzhayyim.apps.vessel.tracking.getVesselPosition",
    "com.etzhayyim.apps.vessel.tracking.listVesselsInArea",
    "com.etzhayyim.apps.maps.aismarine",
    "com.etzhayyim.apps.maps.aircraftLive"
  ],
  "display": {
    "did": "did:web:etzhayyim.com:actor:watari",
    "didDoc": "https://etzhayyim.com/actor/watari/did.json",
    "registry": "50-infra/etzhayyim-did-web/src/registry/infra-actors.ts (INFRA_ACTORS.watari)"
  },
  "gates": {
    "G1": "public transponder broadcasts only — AIS (ships) + ADS-B (aircraft) are open public signals; ingest only these + public registries (ITU MMSI, ICAO 24-bit, national reg). Non-broadcasting / military / blocked-from-display (FAA LADD, PIA) craft = OUT OF SCOPE",
    "G2": "situational-awareness, not surveillance / not targeting — aggregate-first lane/density/congestion routed to safety + collision-avoidance + congestion-easing + resilience; NEVER a 'follow this craft' tool, NEVER a targeting feed (Charter Rider §2(a) force-separation + §2(d); mirrors watatsuna G2)",
    "G3": "aggregate-first + claimed-first output",
    "G4": "no person-tracking / no pattern-of-life — a craft is a craft, not a person; MUST NOT de-anonymize a private-craft owner/crew/passenger, build pattern-of-life on an individual, or answer 'where is person X'. Private-owner identity → encrypted/excluded",
    "G5": "sourcing honesty (:authoritative | :representative | :synthesized) on every node/fix; no fabricated live coverage — absence = 'not yet ingested', a stale fix is reported as stale (freshness tail)",
    "G6": "Murakumo-only narration (ADR-2605215000)",
    "G7": "outward-gated — live AISStream/OpenSky/adsb.fi ingest = Council + operator; R0 ships a bounded seed only",
    "G8": "no git-lfs; bulk position history / replay tiles → DataLad → IPFS (80-data/moving-craft)",
    "G9": "no PII — craft graph only; owner/crew/passenger data → encrypted envelope, excluded by default"
  },
  "nonGoals": {
    "N1": "not a weapons / targeting / fire-control feed (Charter §2(a) force-separation)",
    "N2": "not a person-surveillance / pattern-of-life tool (G4)",
    "N3": "not real-time control — observes craft, never flies/sails one (that is kami-autodrive / funadaiku / watatsumi)",
    "N4": "not a safety-of-life service — NOT GMDSS / ATC / VTS certified; situational-awareness only",
    "N5": "no RisingWave / SQL store — supersedes the legacy maps/vessel position stores",
    "N6": "no military / blocked-from-display craft de-anonymization"
  }
}
